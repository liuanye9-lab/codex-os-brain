{
  "version": "0.3.0",
  "policy": {
    "max_parallel_agents": 4,
    "no_recursive_subagents": false,
    "candidate_only_memory": true,
    "human_approval_required_for": [
      "secrets",
      "credentials",
      "private memory",
      "persona",
      "self-evolution",
      "destructive operations"
    ],
    "dispatch_gate": [
      "每条 Codex 输入都先进入 agentic preflight 调度判断",
      "任务至少包含 3 个明确子步骤",
      "任务有可验证结果",
      "隐私风险为 low，或所选 agent 全部为 read-only",
      "每个 agent 负责不重叠的专业职责",
      "主 Agent 永远负责最终合并、验证和回答"
    ],
    "global_default": "gated_agentic_preflight",
    "fallback": "如果当前 Codex 环境不支持真实 subagent，则只输出本地 dispatch plan，不假装已执行",
    "max_total_agents_per_task": 10,
    "controlled_child_subagents": true,
    "no_unbounded_recursive_subagents": true,
    "child_dispatch_policy": [
      "L2 agents may propose child tasks but must not spawn them directly by default",
      "only architecture-planner and merge-arbiter may request child dispatch",
      "Mother Agent must approve child dispatch before execution",
      "child dispatch requires clear ownership, verification, low privacy risk, and token budget",
      "maximum depth is 2 and maximum child fanout per L2 agent is 2",
      "if token budget or privacy risk is unclear, child dispatch is skipped"
    ]
  },
  "agents": [
    {
      "id": "context-scout",
      "name": "上下文侦察员",
      "type": "explorer",
      "description": "只读探索仓库结构、相关文件、现有模式、测试入口和约束，给主 Agent 提供编辑地图。",
      "when_to_use": [
        "unknown codebase",
        "multi-file change",
        "need file ownership before editing"
      ],
      "inputs": [
        "task",
        "repo path",
        "focus area"
      ],
      "outputs": [
        "相关文件",
        "现有模式",
        "风险点",
        "建议写入范围"
      ],
      "tool_policy": "read_only",
      "write_scope": "none",
      "privacy_level": "low",
      "success_criteria": [
        "names concrete files",
        "does not edit files",
        "returns concise map for parent agent"
      ],
      "failure_modes": [
        "broad summary without file evidence",
        "duplicates another explorer task"
      ],
      "version": "0.1.0",
      "displayName": "上下文侦察员",
      "purpose": "只读探索仓库结构、相关文件、现有模式、测试入口和约束，给主 Agent 提供编辑地图。",
      "nonGoals": [
        "不拥有最终回答",
        "不派生孙子 Agent",
        "不读取私人记忆、密钥或无关用户数据",
        "不绕过主 Agent 的验证和 human approval"
      ],
      "inputSchema": {
        "type": "object",
        "required": [
          "task",
          "repo path",
          "focus area"
        ]
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "relevant files",
          "existing patterns",
          "risks",
          "recommended write scopes"
        ]
      },
      "allowedTools": [
        "read",
        "search"
      ],
      "deniedTools": [
        "secret_read",
        "credential_access",
        "network_without_approval",
        "recursive_spawn",
        "modify_agent_policy"
      ],
      "allowedPaths": [
        "repo-relative read scope"
      ],
      "deniedPaths": [
        "home secrets",
        "private memory",
        ".env",
        "auth files",
        "credentials"
      ],
      "networkPolicy": "explicitApproval",
      "dataPolicy": {
        "rawPrompt": false,
        "rawSecrets": false,
        "logLevel": "sanitized_summary_only"
      },
      "sideEffects": "readOnly",
      "approvalRequiredFor": [
        "secrets",
        "credentials",
        "network",
        "delete files",
        "publish",
        "hooks",
        "memory",
        "persona",
        "self-evolution"
      ],
      "budget": {
        "timeoutMs": 900000,
        "maxToolCalls": 20,
        "maxFiles": 30,
        "tokenBudget": "bounded"
      },
      "recursionPolicy": {
        "allowSpawn": false,
        "maxDepth": 1,
        "maxFanout": 0
      },
      "stopConditions": [
        "success evidence produced",
        "blocked by privacy or permission",
        "timeout",
        "scope expansion required"
      ],
      "verification": [
        "names concrete files",
        "does not edit files",
        "returns concise map for parent agent"
      ],
      "redaction": [
        "remove secrets",
        "remove private home paths",
        "summarize raw prompts"
      ],
      "auditLogFields": [
        "runId",
        "parentRunId",
        "agentId",
        "taskHash",
        "permissionProfile",
        "riskLevel",
        "evidenceSummary"
      ],
      "ownerReview": "主 Agent 必须审查后才能合并或声明完成"
    },
