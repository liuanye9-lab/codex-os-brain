{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex-brain/brain-v9-event.schema.json",
  "title": "Codex Brain V9 Sanitized Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "eventId", "kind"],
  "properties": {
    "schemaVersion": { "const": 9 },
    "eventId": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["session", "prompt", "tool", "failure", "compact", "completion", "checkpoint", "migration"] },
    "taskId": { "type": "string" },
    "turnId": { "type": "string" },
    "status": { "enum": ["observed", "passed", "failed", "blocked", "unverified"] },
    "reasonCode": { "type": "string" },
    "signature": { "type": "string", "pattern": "^sig_[a-f0-9]{24}$" },
    "evidenceId": { "type": "string" },
    "durationMs": { "type": "number", "minimum": 0 },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
