{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Brain Lite Verifier-Backed Routing Receipt Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "task", "route", "execution", "verification", "delivery"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taskId", "taskFamily", "taskFingerprint", "risk"],
      "properties": {
        "taskId": { "type": "string", "minLength": 1 },
        "taskFamily": { "type": "string", "minLength": 1 },
        "taskFingerprint": { "type": "string", "minLength": 8 },
        "risk": { "enum": ["low", "medium", "high", "critical"] },
        "relevantFiles": { "type": "array", "items": { "type": "string" } }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routeId", "executionMode", "attempt", "maxAttempts"],
      "properties": {
        "routeId": { "type": "string", "minLength": 1 },
        "model": { "type": ["string", "null"] },
        "effort": { "type": ["string", "null"] },
        "policyVersion": { "type": ["string", "null"] },
        "traceId": { "type": "string" },
        "executionMode": { "enum": ["mother-direct", "delegated"] },
        "attempt": { "type": "integer", "minimum": 1 },
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "probe": { "type": "boolean" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputTokens": { "type": "integer", "minimum": 0 },
        "cachedInputTokens": { "type": "integer", "minimum": 0 },
        "outputTokens": { "type": "integer", "minimum": 0 },
        "durationMs": { "type": "integer", "minimum": 0 },
        "exitStatus": { "type": "integer" },
        "modelClaimedSuccess": { "type": "boolean" },
        "infrastructureFailure": { "type": "boolean" },
        "infrastructureFailureType": { "type": ["string", "null"] }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["failureAttribution", "checks"],
      "properties": {
        "failureAttribution": { "enum": ["model-capability", "pre-existing", "verification-infrastructure", "unknown"] },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "command"],
            "properties": {
              "id": { "type": ["string", "null"] },
              "kind": { "type": "string" },
              "command": { "type": "string", "minLength": 1 },
              "args": { "type": "array", "items": { "type": "string" } },
              "timeoutMs": { "type": "integer", "minimum": 1000, "maximum": 1200000 },
              "expectedExitStatus": { "type": "integer" }
            }
          }
        },
        "artifacts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finalDelivered"],
      "properties": {
        "finalDelivered": { "type": "boolean" },
        "userCorrected": { "type": "boolean" },
        "criticalFailure": { "type": "boolean" }
      }
    }
  }
}
