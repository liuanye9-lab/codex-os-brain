{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/brain-v9-recovery-share.schema.json",
  "title": "Codex Brain 2-of-2 encrypted recovery share",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "packageType", "ceremonyId", "shareIndex", "shareTotal", "keyFingerprint", "createdAt", "kdf", "encryption", "ciphertext"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "packageType": { "const": "codex-brain-recovery-share" },
    "ceremonyId": { "type": "string", "pattern": "^cer_[a-f0-9]{24}$" },
    "shareIndex": { "enum": [1, 2] },
    "shareTotal": { "const": 2 },
    "keyFingerprint": { "type": "string", "pattern": "^key_[a-f0-9]{24}$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "kdf": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "N", "r", "p", "keyLength", "salt"],
      "properties": {
        "name": { "const": "scrypt" }, "N": { "const": 131072 }, "r": { "const": 8 }, "p": { "const": 1 }, "keyLength": { "const": 32 }, "salt": { "type": "string" }
      }
    },
    "encryption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "iv", "tag"],
      "properties": { "algorithm": { "const": "aes-256-gcm" }, "iv": { "type": "string" }, "tag": { "type": "string" } }
    },
    "ciphertext": { "type": "string" }
  }
}
