{
  "version": 1,
  "entries": [
    { "source": "config/public-package.json", "target": "package.json" },
    { "source": "README.md", "target": "README.md" },
    { "source": "LICENSE", "target": "LICENSE" },
    { "source": "config/brain-lite-v9.json", "target": "config/brain-lite-v9.json" },
